{
	"agentConfig": {
		"permissions": "bypass-permissions"
	},
	"autonomousMerge": true,
	"defaultBranch": "main",
	"env": {
		"POLYPOWERS_REPO": "polymath-ventures/agent-orchestrator"
	},
	"orchestrator": {
		"agent": "claude-code",
		"agentConfig": {
			"model": "opus"
		},
		"instructionsFile": ".claude/orchestrator-policy.md",
		"wakeBackoff": {
			"base": "15m",
			"enabled": true,
			"max": "1h"
		}
	},
	"prime": {
		"agent": "claude-code",
		"agentConfig": {
			"model": "opus"
		},
		"instructionsFile": ".claude/prime-orchestrator-policy.md",
		"wakeBackoff": {
			"base": "15m",
			"enabled": true,
			"max": "1h"
		}
	},
	"projectPrefix": "ao",
	"trackerIntake": {
		"assignee": "*",
		"enabled": true,
		"maxConcurrent": 2,
		"provider": "github",
		"respawn": {
			"disabled": true,
			"maxRetries": 0
		}
	},
	"worker": {
		"agent": "codex",
		"agentConfig": {
			"model": "gpt-5.5"
		}
	},
	"workerMix": [
		{
			"agent": "codex",
			"model": "gpt-5.5",
			"weight": 55
		},
		{
			"agent": "codex-fugu",
			"model": "fugu-ultra",
			"weight": 27
		},
		{
			"agent": "claude-code",
			"model": "opus",
			"weight": 18
		}
	],
	"workspace": "in-place"
}
